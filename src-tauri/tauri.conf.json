{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "codex_switch",
  "version": "0.1.0",
  "identifier": "com.cmochance.codexswitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Switch",
        "width": 1280,
        "height": 744,
        "minWidth": 1152,
        "minHeight": 670,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
